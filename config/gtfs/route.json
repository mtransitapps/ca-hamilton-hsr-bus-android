      "ignore_case": true,
      "is_word": true,
      "replacement": "Waterfront"
    },
    {
      "regex": "power (centre|center)",
      "ignore_case": true,
      "is_word": true,
      "replacement": "PC"
    },
    {
      "regex": "(^(aldershot go - ))",
      "ignore_case": true
    }
  ],
  "stop_id_clean_merged": true,
  "stop_name_cleaners": [
    {
      "regex": "((\\s+)(opposite|opp)(\\s+))",
